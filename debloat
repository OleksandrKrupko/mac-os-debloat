_SCRIPT_FILE = globals().get("__file__")
LABELS_FILE = Path(_SCRIPT_FILE).parent / "labels.txt" if _SCRIPT_FILE else None


@dataclass
class Item:
    label: str
    comment: str
    section: str
    disabled: bool = False
    selected: bool = False


@dataclass
class Section:
    title: str
    items: list[Item] = field(default_factory=list)


def parse_labels(source: Path | str) -> list[Section]:
    text = source.read_text() if isinstance(source, Path) else source
    sections: list[Section] = []
    current = Section(title="(uncategorized)")
    for raw in text.splitlines():
        line = raw.rstrip()
        if not line.strip():
            continue
        m = re.match(r"^#\s*===\s*(.+?)\s*===\s*$", line)
        if m:
            if current.items:
                sections.append(current)
            current = Section(title=m.group(1))
            continue
        if line.lstrip().startswith("#"):
            continue
        if "#" in line:
            label_part, comment = line.split("#", 1)
            label = label_part.strip()
            comment = comment.strip()
        else:
            label = line.strip()
            comment = ""
        if label:
            current.items.append(Item(label=label, comment=comment, section=current.title))
    if current.items:
        sections.append(current)
    return sections


def installed_plist_labels() -> set[str]:
    names: set[str] = set()
    for d in LAUNCHD_DIRS:
        for p in glob.glob(d + "/*.plist"):
            names.add(os.path.basename(p)[:-6])
    return names


def label_present(label: str, plist_names: set[str]) -> bool:
    if label in plist_names:
        return True
    for domain in ("system", f"gui/{UID}"):
        r = subprocess.run(["launchctl", "print", f"{domain}/{label}"],
                           capture_output=True, check=False)
        if r.returncode == 0:
            return True
    return False


def drop_absent_labels(sections: list[Section]) -> list[str]:
    """Remove labels that don't exist on this macOS build (renamed/removed by
    Apple, or wrong on this OS). Returns the dropped labels so callers can
    report them. Prevents phantom entries showing as enabled no-ops."""
    plist_names = installed_plist_labels()
    absent: list[str] = []
    for sec in sections:
        keep: list[Item] = []
        for it in sec.items:
            if label_present(it.label, plist_names):
                keep.append(it)
            else:
                absent.append(it.label)
        sec.items = keep
    sections[:] = [s for s in sections if s.items]
    return absent


def query_disabled(domain: str) -> set[str]:
    result = subprocess.run(
        ["launchctl", "print-disabled", domain],
        capture_output=True, text=True, check=False,
    )
    disabled: set[str] = set()
    for line in result.stdout.splitlines():
        m = re.match(r'\s*"([^"]+)"\s*=>\s*(true|disabled)\s*$', line)
        if m:
            disabled.add(m.group(1))
    return disabled


def refresh_state(sections: list[Section]) -> None:
    sys_dis = query_disabled("system")
    gui_dis = query_disabled(f"gui/{UID}")
    for sec in sections:
        for it in sec.items:
            it.disabled = it.label in sys_dis or it.label in gui_dis
            it.selected = not it.disabled


def find_pids_for_labels(labels: list[str]) -> dict[str, list[int]]:
    """Return {label: [pids]} for labels with matching running processes.
    Matches by basename of executable equal to label's last segment,
    or by label appearing in full command line."""
    if not labels:
        return {}
    r = subprocess.run(["ps", "-axm", "-o", "pid=,comm="],
                       capture_output=True, text=True, check=False)
    short_to_label: dict[str, str] = {}
    for lab in labels:
        short_to_label[lab.rsplit(".", 1)[-1]] = lab
    label_set = set(labels)
    out: dict[str, list[int]] = {}
    for line in r.stdout.splitlines():
        parts = line.strip().split(None, 1)
        if len(parts) < 2:
            continue
        pid_str, cmd = parts
        try:
            pid = int(pid_str)
        except ValueError:
            continue
        cmd_short = cmd.rsplit("/", 1)[-1]
        if cmd_short in short_to_label:
            out.setdefault(short_to_label[cmd_short], []).append(pid)
            continue
        for lab in label_set:
            if lab in cmd:
                out.setdefault(lab, []).append(pid)
                break
    return out


def pending_changes(sections: list[Section]) -> tuple[list[str], list[str]]:
    to_disable: list[str] = []
    to_enable: list[str] = []
    for sec in sections:
        for it in sec.items:
            wants_enabled = it.selected
            is_enabled = not it.disabled
            if wants_enabled and not is_enabled:
                to_enable.append(it.label)
            elif not wants_enabled and is_enabled:
                to_disable.append(it.label)
    return to_disable, to_enable


def apply_changes(sections: list[Section]) -> dict:
    to_disable, to_enable = pending_changes(sections)

    # Phase 1: launchctl disable + bootout (or enable)
    for label in to_disable:
        for domain in (f"gui/{UID}", "system"):
            subprocess.run(["sudo", "launchctl", "disable", f"{domain}/{label}"],
                           capture_output=True, check=False)
            subprocess.run(["sudo", "launchctl", "bootout", f"{domain}/{label}"],
                           capture_output=True, check=False)
    for label in to_enable:
        for domain in (f"gui/{UID}", "system"):
            subprocess.run(["sudo", "launchctl", "enable", f"{domain}/{label}"],
                           capture_output=True, check=False)

    # Phase 2: nuclear kill -9 for anything still running after bootout
    killed = 0
    if to_disable:
        survivors = find_pids_for_labels(to_disable)
        for label, pids in survivors.items():
            for pid in pids:
                r = subprocess.run(["sudo", "kill", "-9", str(pid)],
                                   capture_output=True, check=False)
                if r.returncode == 0:
                    killed += 1

    # Phase 3: brief settle then verify nothing respawned
    time.sleep(0.4)
    stragglers: dict[str, list[int]] = {}
    if to_disable:
        stragglers = find_pids_for_labels(to_disable)

    return {
        "disabled": len(to_disable),
        "enabled": len(to_enable),
        "killed": killed,
        "stragglers": stragglers,
    }


def reopen_tty_stdin() -> bool:
    """`curl ... | python3` feeds the script on stdin, leaving fd 0 as a spent
    pipe rather than a terminal. curses then busy-loops on getch (ERR, spawning
    mdutil every frame) or fails cbreak outright. Point fd 0 at the controlling
    terminal so the TUI reads real keystrokes."""
    if sys.stdin.isatty():
        return True
    try:
        tty = open("/dev/tty")
    except OSError:
        return False
    os.dup2(tty.fileno(), 0)
    sys.stdin = tty
    return True


def prime_sudo() -> bool:
    result = subprocess.run(["sudo", "-v"], check=False)
    return result.returncode == 0


def spotlight_state() -> str:
    """Return 'on', 'off', or 'indexing' for the root data volume.

    A wiped/rebuilding index reports neither enabled nor disabled but an
    "unknown" state, which means a reindex is in progress (truly on once done).
    """
    r = subprocess.run(["mdutil", "-s", "/System/Volumes/Data"],
                       capture_output=True, text=True, check=False)
    if "Indexing enabled" in r.stdout:
        return "on"
    if "Indexing disabled" in r.stdout:
        return "off"
    return "indexing"


def spotlight_status_line() -> str:
    label = {"on": "ON", "off": "OFF", "indexing": "INDEXING (rebuilding)"}[spotlight_state()]
    return f"spotlight: {label}"


def spotlight_set(enabled: bool) -> tuple[bool, str]:
    flag = "on" if enabled else "off"
    r = subprocess.run(["sudo", "mdutil", "-a", "-i", flag],
                       capture_output=True, text=True, check=False)
    if r.returncode != 0:
        return False, f"mdutil failed: {r.stderr.strip()}"
    if enabled:
        # `-i on` only sets the flag; a previously disabled index stays in an
        # "unknown" state and never rebuilds, so Finder metadata queries hang.
        # Force a clean erase+reindex so enabling is truly on.
        e = subprocess.run(["sudo", "mdutil", "-a", "-E"],
                           capture_output=True, text=True, check=False)
        if e.returncode != 0:
            return False, f"mdutil -E failed: {e.stderr.strip()}"
        return True, "spotlight indexing enabled - reindex running (~10-30 min)"
    return True, "spotlight indexing disabled"


def flat_index(sections: list[Section]) -> list[Item]:
    out: list[Item] = []
    for sec in sections:
        for it in sec.items:
            out.append(it)
    return out


def section_of(sections: list[Section], item: Item) -> Section | None:
    for sec in sections:
        if item in sec.items:
            return sec
    return None


def jump_section(sections: list[Section], flat: list[Item], cursor: int, direction: int) -> int:
    """Move cursor to first item of next/prev section."""
    sec_start_indices: list[int] = []
    idx = 0
    for sec in sections:
        if sec.items:
            sec_start_indices.append(idx)
            idx += len(sec.items)
    if not sec_start_indices:
        return cursor
    if direction > 0:
        for s in sec_start_indices:
            if s > cursor:
                return s
        return sec_start_indices[-1]
    else:
        prev = sec_start_indices[0]
        for s in sec_start_indices:
            if s >= cursor:
                return prev
            prev = s
        return sec_start_indices[-1]


def build_display_rows(sections: list[Section]) -> tuple[list[tuple[str, object]], dict[int, int]]:
    """Return (display_rows, item_idx_to_row_idx).
    display_rows entries: ("section", title) | ("item", Item) | ("blank", None)."""
    rows: list[tuple[str, object]] = []
    item_to_row: dict[int, int] = {}
    item_idx = 0
    for sec in sections:
        rows.append(("section", sec.title))
        for it in sec.items:
            item_to_row[item_idx] = len(rows)
            rows.append(("item", it))
            item_idx += 1
        rows.append(("blank", None))
    return rows, item_to_row


def draw(stdscr, sections: list[Section], cursor: int, status: str, scroll: list[int]) -> None:
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    title = "mac-os-debloat  —  space=toggle  x=sec-toggle  s/S=sec-off/on  [/]=jump  a/n=all/none  p=spotlight  enter=apply  q=quit"
    stdscr.addnstr(0, 0, title[:w - 1], w - 1, curses.A_BOLD)

    diff_count = sum(
        1 for sec in sections for it in sec.items if it.selected == it.disabled
    )
    sub = f"pending: {diff_count}   ({spotlight_status_line()})   (checked = enabled/running)"
    stdscr.addnstr(1, 0, sub[:w - 1], w - 1, curses.A_DIM)

    rows, item_to_row = build_display_rows(sections)
    content_top = 3
    content_bottom = h - 1
    visible_h = max(1, content_bottom - content_top)

    cursor_row = item_to_row.get(cursor, 0)
    so = scroll[0]
    if cursor_row < so:
        so = cursor_row
    elif cursor_row >= so + visible_h:
        so = cursor_row - visible_h + 1
    so = max(0, min(so, max(0, len(rows) - visible_h)))
    scroll[0] = so

    flat = flat_index(sections)
    item_by_id = {id(it): i for i, it in enumerate(flat)}

    for screen_row, i in enumerate(range(so, min(so + visible_h, len(rows)))):
        kind, payload = rows[i]
        y = content_top + screen_row
        if kind == "section":
            line = f"── {payload} ".ljust(w - 1, "─")[:w - 1]
            stdscr.addnstr(y, 0, line, w - 1, curses.A_DIM)
        elif kind == "item":
            it = payload  # type: ignore[assignment]
            mark = "[✓]" if it.selected else "[ ]"
            changed = " *" if it.selected == it.disabled else "  "
            text = f"{changed}{mark}  {it.label:<48}  {it.comment}"
            is_cursor = item_by_id.get(id(it)) == cursor
            attr = curses.A_REVERSE if is_cursor else curses.A_NORMAL
            stdscr.addnstr(y, 0, text[:w - 1], w - 1, attr)
        # blank: leave row empty

    if so > 0:
        try:
            stdscr.addnstr(content_top, max(0, w - 2), "↑", 1, curses.A_DIM)
        except curses.error:
            pass
    if so + visible_h < len(rows):
        try:
            stdscr.addnstr(content_bottom - 1, max(0, w - 2), "↓", 1, curses.A_DIM)
        except curses.error:
            pass

    if status:
        try:
            stdscr.addnstr(h - 1, 0, status[:w - 1], w - 1, curses.A_BOLD)
        except curses.error:
            pass
    stdscr.refresh()


def run_tui(stdscr, sections: list[Section]) -> str | None:
    curses.curs_set(0)
    cursor = 0
    status = ""
    scroll = [0]
    flat = flat_index(sections)
    while True:
        if not flat:
            return "no labels"
        cursor = max(0, min(cursor, len(flat) - 1))
        draw(stdscr, sections, cursor, status, scroll)
        status = ""
        c = stdscr.getch()
        if c in (ord("q"), 27):
            return None
        if c in (curses.KEY_DOWN, ord("j")):
            cursor = min(cursor + 1, len(flat) - 1)
        elif c in (curses.KEY_UP, ord("k")):
            cursor = max(cursor - 1, 0)
        elif c == curses.KEY_NPAGE:
            cursor = min(cursor + 10, len(flat) - 1)
        elif c == curses.KEY_PPAGE:
            cursor = max(cursor - 10, 0)
        elif c == ord(" "):
            flat[cursor].selected = not flat[cursor].selected
        elif c == ord("a"):
            for it in flat:
                it.selected = True
        elif c == ord("n"):
            for it in flat:
                it.selected = False
        elif c == ord("s"):
            sec = section_of(sections, flat[cursor])
            if sec:
                for it in sec.items:
                    it.selected = False
                status = f"unchecked section: {sec.title}"
        elif c == ord("S"):
            sec = section_of(sections, flat[cursor])
            if sec:
                for it in sec.items:
                    it.selected = True
                status = f"checked section: {sec.title}"
        elif c == ord("x"):
            sec = section_of(sections, flat[cursor])
            if sec:
                all_on = all(it.selected for it in sec.items)
                for it in sec.items:
                    it.selected = not all_on
                status = f"toggled section: {sec.title}"
        elif c == ord("]"):
            cursor = jump_section(sections, flat, cursor, direction=1)
        elif c == ord("["):
            cursor = jump_section(sections, flat, cursor, direction=-1)
        elif c == ord("r"):
            curses.endwin()
            if not prime_sudo():
                return "sudo failed"
            refresh_state(sections)
            stdscr.clear()
            status = "state reloaded"
        elif c == ord("p"):
            curses.endwin()
            if not prime_sudo():
                return "sudo failed"
            ok, msg = spotlight_set(spotlight_state() == "off")
            stdscr.clear()
            status = msg
        elif c in (curses.KEY_ENTER, 10, 13):
            curses.endwin()
            if not prime_sudo():
                return "sudo failed"
            write_snapshot(sections)
            result = apply_changes(sections)
            refresh_state(sections)
            stdscr.clear()
            straglen = len(result["stragglers"])
            status = (
                f'applied: {result["disabled"]} disabled, {result["enabled"]} enabled, '
                f'{result["killed"]} killed'
            )
            if straglen:
                status += f"  ⚠ {straglen} respawned (see terminal after quit)"
                # Print stragglers to stdout for visibility after TUI exits
                sys.stderr.write(f"\n[debloat] {straglen} stragglers (respawned by launchd):\n")
                for label, pids in result["stragglers"].items():
                    sys.stderr.write(f"  {label}  pids={pids}\n")


def macos_major() -> int | None:
    r = subprocess.run(["sw_vers", "-productVersion"],
                       capture_output=True, text=True, check=False)
    part = r.stdout.strip().split(".")[0]
    return int(part) if part.isdigit() else None


def mem_free_mb() -> int | None:
    """Reclaimable RAM (free + inactive + speculative + purgeable) in MB."""
    r = subprocess.run(["vm_stat"], capture_output=True, text=True, check=False)
    if r.returncode != 0:
        return None
    page = re.search(r"page size of (\d+) bytes", r.stdout)
    if not page:
        return None
    page_bytes = int(page.group(1))
    pages = 0
    for key in ("Pages free", "Pages inactive", "Pages speculative", "Pages purgeable"):
        m = re.search(rf"{key}:\s+(\d+)\.", r.stdout)
        if m:
            pages += int(m.group(1))
    return pages * page_bytes // (1024 * 1024)


def write_snapshot(sections: list[Section]) -> Path:
    BACKUP_DIR.mkdir(parents=True, exist_ok=True)
    disabled = [it.label for sec in sections for it in sec.items if it.disabled]
    build = subprocess.run(["sw_vers", "-buildVersion"],
                           capture_output=True, text=True, check=False).stdout.strip()
    snap = {"build": build, "disabled": disabled}
    (BACKUP_DIR / "latest.json").write_text(json.dumps(snap, indent=2))
    return BACKUP_DIR / "latest.json"


def load_snapshot() -> dict | None:
    path = BACKUP_DIR / "latest.json"
    if not path.exists():
        return None
    return json.loads(path.read_text())


def run_apply(sections: list[Section], dry_run: bool) -> int:
    to_disable, to_enable = pending_changes(sections)
    if not to_disable and not to_enable:
        print("nothing to change — already in the requested state")
        return 0
    if dry_run:
        print(f"[dry-run] would disable {len(to_disable)}, enable {len(to_enable)}:")
        for label in to_disable:
            print(f"  disable  {label}")
        for label in to_enable:
            print(f"  enable   {label}")
        return 0
    if not prime_sudo():
        print("sudo required to change launchd state", file=sys.stderr)
        return 1
    write_snapshot(sections)
    result = apply_changes(sections)
    print(f'applied: {result["disabled"]} disabled, {result["enabled"]} enabled, '
          f'{result["killed"]} killed')
    stragglers = result["stragglers"]
    if stragglers:
        print(f"{len(stragglers)} respawned by launchd:", file=sys.stderr)
        for label, pids in stragglers.items():
            print(f"  {label}  pids={pids}", file=sys.stderr)
    return 0


def cmd_status(sections: list[Section], as_json: bool) -> int:
    refresh_state(sections)
    disabled = sum(1 for sec in sections for it in sec.items if it.disabled)
    total = sum(len(sec.items) for sec in sections)
    spot = spotlight_state()
    free = mem_free_mb()
    if as_json:
        print(json.dumps({
            "labels_present": total,
            "disabled": disabled,
            "enabled": total - disabled,
            "spotlight": spot,
            "reclaimable_ram_mb": free,
        }, indent=2))
        return 0
    print(f"labels present on this macOS: {total}")
    print(f"  disabled: {disabled}   enabled: {total - disabled}")
    print(f"spotlight: {spot}")
    if free is not None:
        print(f"reclaimable RAM now: ~{free} MB")
    return 0


def cmd_audit(sections: list[Section], absent: list[str]) -> int:
    present = sum(len(sec.items) for sec in sections)
    print(f"{present} labels present on this macOS build.")
    if absent:
        print(f"\n{len(absent)} embedded labels NOT present on this build (skipped):")
        for label in absent:
            print(f"  {label}")
    else:
        print("all embedded labels exist on this build.")
    return 0


def cmd_restore(sections: list[Section]) -> int:
    snap = load_snapshot()
    if snap is None:
        print(f"no backup found at {BACKUP_DIR / 'latest.json'}", file=sys.stderr)
        return 1
    if not prime_sudo():
        print("sudo required to change launchd state", file=sys.stderr)
        return 1
    refresh_state(sections)
    prev_disabled = set(snap["disabled"])
    for sec in sections:
        for it in sec.items:
            it.selected = it.label not in prev_disabled
    print(f"restoring pre-apply state ({len(prev_disabled)} were disabled)...")
    return run_apply(sections, dry_run=False)


def load_sections() -> tuple[list[Section], str, list[str]]:
    if LABELS_FILE and LABELS_FILE.exists():
        sections = parse_labels(LABELS_FILE)
        note = f"loaded labels from {LABELS_FILE}"
    else:
        sections = parse_labels(EMBEDDED_LABELS)
        note = "using embedded labels (no labels.txt found)"
    absent = drop_absent_labels(sections)
    return sections, note, absent


VERSION = "0.5.1"

HELP = f"""mac-os-debloat {VERSION} — toggle non-essential macOS launchd services.

Runs a live SIP-safe launchctl TUI by default (no SIP disable required).

Usage:
  debloat                 interactive TUI (default)
  debloat --status        print disabled/enabled counts, spotlight, free RAM
  debloat --audit         list embedded labels not present on this macOS build
  debloat --disable-all   disable every non-essential service (prompts sudo)
  debloat --enable-all    re-enable everything — the panic button
  debloat --restore       revert to the state before your last apply
  debloat --dry-run       with --disable-all/--enable-all: preview, don't apply
  debloat --json          with --status: machine-readable output
  debloat -v|--version    print version
  debloat -h|--help       this help
"""


def main() -> int:
    argv = sys.argv[1:]
    if "-h" in argv or "--help" in argv:
        print(HELP)
        return 0
    if "-v" in argv or "--version" in argv:
        print(f"mac-os-debloat {VERSION}")
        return 0

    major = macos_major()
    if major is not None and major != 26:
        print(f"warning: labels curated for macOS Tahoe (26.x); this is {major}.x — "
              f"some may not apply. Run `debloat --audit` to see what's skipped.",
              file=sys.stderr)

    sections, source_note, absent = load_sections()
    if not sections:
        print("no labels parsed", file=sys.stderr)
        return 1

    dry_run = "--dry-run" in argv
    as_json = "--json" in argv

    if "--audit" in argv:
        return cmd_audit(sections, absent)
    if "--status" in argv:
        return cmd_status(sections, as_json)
    if "--restore" in argv:
        return cmd_restore(sections)
    if "--enable-all" in argv or "--disable-all" in argv:
        refresh_state(sections)
        want_enabled = "--enable-all" in argv
        for sec in sections:
            for it in sec.items:
                it.selected = want_enabled
        return run_apply(sections, dry_run)

    print(source_note)
    if absent:
        print(f"skipped {len(absent)} labels not present on this macOS build "
              f"(see `debloat --audit`)")
    if not reopen_tty_stdin():
        print("the interactive TUI needs a terminal on stdin, but none is "
              "attached.\nUse the npx launcher, or download then run:\n"
              "  curl -fsSL https://raw.githubusercontent.com/OleksandrKrupko/"
              "mac-os-debloat/main/debloat -o /tmp/debloat && python3 /tmp/debloat\n"
              "Non-interactive flags (--status, --disable-all, ...) work over a "
              "pipe.", file=sys.stderr)
        return 1
    refresh_state(sections)
    result = curses.wrapper(run_tui, sections)
    if result:
        print(result)
    return 0


if __name__ == "__main__":
    sys.exit(main())

_SCRIPT_FILE = globals().get("__file__")
LABELS_FILE = Path(_SCRIPT_FILE).parent / "labels.txt" if _SCRIPT_FILE else None


@dataclass
class Item:
    label: str
    comment: str
    section: str
    disabled: bool = False
    selected: bool = False


@dataclass
class Section:
    title: str
    items: list[Item] = field(default_factory=list)


def parse_labels(source: Path | str) -> list[Section]:
    text = source.read_text() if isinstance(source, Path) else source
    sections: list[Section] = []
    current = Section(title="(uncategorized)")
    for raw in text.splitlines():
        line = raw.rstrip()
        if not line.strip():
            continue
        m = re.match(r"^#\s*===\s*(.+?)\s*===\s*$", line)
        if m:
            if current.items:
                sections.append(current)
            current = Section(title=m.group(1))
            continue
        if line.lstrip().startswith("#"):
            continue
        if "#" in line:
            label_part, comment = line.split("#", 1)
            label = label_part.strip()
            comment = comment.strip()
        else:
            label = line.strip()
            comment = ""
        if label:
            current.items.append(Item(label=label, comment=comment, section=current.title))
    if current.items:
        sections.append(current)
    return sections


def query_disabled(domain: str) -> set[str]:
    result = subprocess.run(
        ["sudo", "-n", "launchctl", "print-disabled", domain],
        capture_output=True, text=True, check=False,
    )
    disabled: set[str] = set()
    for line in result.stdout.splitlines():
        m = re.match(r'\s*"([^"]+)"\s*=>\s*(true|disabled)\s*$', line)
        if m:
            disabled.add(m.group(1))
    return disabled


def refresh_state(sections: list[Section]) -> None:
    sys_dis = query_disabled("system")
    gui_dis = query_disabled(f"gui/{UID}")
    for sec in sections:
        for it in sec.items:
            it.disabled = it.label in sys_dis or it.label in gui_dis
            it.selected = not it.disabled


def find_pids_for_labels(labels: list[str]) -> dict[str, list[int]]:
    """Return {label: [pids]} for labels with matching running processes.
    Matches by basename of executable equal to label's last segment,
    or by label appearing in full command line."""
    if not labels:
        return {}
    r = subprocess.run(["ps", "-axm", "-o", "pid=,comm="],
                       capture_output=True, text=True, check=False)
    short_to_label: dict[str, str] = {}
    for lab in labels:
        short_to_label[lab.rsplit(".", 1)[-1]] = lab
    label_set = set(labels)
    out: dict[str, list[int]] = {}
    for line in r.stdout.splitlines():
        parts = line.strip().split(None, 1)
        if len(parts) < 2:
            continue
        pid_str, cmd = parts
        try:
            pid = int(pid_str)
        except ValueError:
            continue
        cmd_short = cmd.rsplit("/", 1)[-1]
        if cmd_short in short_to_label:
            out.setdefault(short_to_label[cmd_short], []).append(pid)
            continue
        for lab in label_set:
            if lab in cmd:
                out.setdefault(lab, []).append(pid)
                break
    return out


def apply_changes(sections: list[Section]) -> dict:
    import time

    to_disable: list[str] = []
    to_enable: list[str] = []
    for sec in sections:
        for it in sec.items:
            wants_enabled = it.selected
            is_enabled = not it.disabled
            if wants_enabled and not is_enabled:
                to_enable.append(it.label)
            elif not wants_enabled and is_enabled:
                to_disable.append(it.label)

    # Phase 1: launchctl disable + bootout (or enable)
    for label in to_disable:
        for domain in (f"gui/{UID}", "system"):
            subprocess.run(["sudo", "launchctl", "disable", f"{domain}/{label}"],
                           capture_output=True, check=False)
            subprocess.run(["sudo", "launchctl", "bootout", f"{domain}/{label}"],
                           capture_output=True, check=False)
    for label in to_enable:
        for domain in (f"gui/{UID}", "system"):
            subprocess.run(["sudo", "launchctl", "enable", f"{domain}/{label}"],
                           capture_output=True, check=False)

    # Phase 2: nuclear kill -9 for anything still running after bootout
    killed = 0
    if to_disable:
        survivors = find_pids_for_labels(to_disable)
        for label, pids in survivors.items():
            for pid in pids:
                r = subprocess.run(["sudo", "kill", "-9", str(pid)],
                                   capture_output=True, check=False)
                if r.returncode == 0:
                    killed += 1

    # Phase 3: brief settle then verify nothing respawned
    time.sleep(0.4)
    stragglers: dict[str, list[int]] = {}
    if to_disable:
        stragglers = find_pids_for_labels(to_disable)

    return {
        "disabled": len(to_disable),
        "enabled": len(to_enable),
        "killed": killed,
        "stragglers": stragglers,
    }


def prime_sudo() -> bool:
    result = subprocess.run(["sudo", "-v"], check=False)
    return result.returncode == 0


def flat_index(sections: list[Section]) -> list[Item]:
    out: list[Item] = []
    for sec in sections:
        for it in sec.items:
            out.append(it)
    return out


def section_of(sections: list[Section], item: Item) -> Section | None:
    for sec in sections:
        if item in sec.items:
            return sec
    return None


def jump_section(sections: list[Section], flat: list[Item], cursor: int, direction: int) -> int:
    """Move cursor to first item of next/prev section."""
    sec_start_indices: list[int] = []
    idx = 0
    for sec in sections:
        if sec.items:
            sec_start_indices.append(idx)
            idx += len(sec.items)
    if not sec_start_indices:
        return cursor
    if direction > 0:
        for s in sec_start_indices:
            if s > cursor:
                return s
        return sec_start_indices[-1]
    else:
        prev = sec_start_indices[0]
        for s in sec_start_indices:
            if s >= cursor:
                return prev
            prev = s
        return sec_start_indices[-1]


def build_display_rows(sections: list[Section]) -> tuple[list[tuple[str, object]], dict[int, int]]:
    """Return (display_rows, item_idx_to_row_idx).
    display_rows entries: ("section", title) | ("item", Item) | ("blank", None)."""
    rows: list[tuple[str, object]] = []
    item_to_row: dict[int, int] = {}
    item_idx = 0
    for sec in sections:
        rows.append(("section", sec.title))
        for it in sec.items:
            item_to_row[item_idx] = len(rows)
            rows.append(("item", it))
            item_idx += 1
        rows.append(("blank", None))
    return rows, item_to_row


def draw(stdscr, sections: list[Section], cursor: int, status: str, scroll: list[int]) -> None:
    stdscr.erase()
    h, w = stdscr.getmaxyx()
    title = "mac-os-debloat  —  space=toggle  x=section-toggle  s/S=section-off/on  [/]=jump  a/n=all/none  enter=apply  q=quit"
    stdscr.addnstr(0, 0, title[:w - 1], w - 1, curses.A_BOLD)

    diff_count = sum(
        1 for sec in sections for it in sec.items if it.selected == it.disabled
    )
    sub = f"pending changes: {diff_count}   (checked = enabled/running, unchecked = disabled)"
    stdscr.addnstr(1, 0, sub[:w - 1], w - 1, curses.A_DIM)

    rows, item_to_row = build_display_rows(sections)
    content_top = 3
    content_bottom = h - 1
    visible_h = max(1, content_bottom - content_top)

    cursor_row = item_to_row.get(cursor, 0)
    so = scroll[0]
    if cursor_row < so:
        so = cursor_row
    elif cursor_row >= so + visible_h:
        so = cursor_row - visible_h + 1
    so = max(0, min(so, max(0, len(rows) - visible_h)))
    scroll[0] = so

    flat = flat_index(sections)
    item_by_id = {id(it): i for i, it in enumerate(flat)}

    for screen_row, i in enumerate(range(so, min(so + visible_h, len(rows)))):
        kind, payload = rows[i]
        y = content_top + screen_row
        if kind == "section":
            line = f"── {payload} ".ljust(w - 1, "─")[:w - 1]
            stdscr.addnstr(y, 0, line, w - 1, curses.A_DIM)
        elif kind == "item":
            it = payload  # type: ignore[assignment]
            mark = "[✓]" if it.selected else "[ ]"
            changed = " *" if it.selected == it.disabled else "  "
            text = f"{changed}{mark}  {it.label:<48}  {it.comment}"
            is_cursor = item_by_id.get(id(it)) == cursor
            attr = curses.A_REVERSE if is_cursor else curses.A_NORMAL
            stdscr.addnstr(y, 0, text[:w - 1], w - 1, attr)
        # blank: leave row empty

    if so > 0:
        try:
            stdscr.addnstr(content_top, max(0, w - 2), "↑", 1, curses.A_DIM)
        except curses.error:
            pass
    if so + visible_h < len(rows):
        try:
            stdscr.addnstr(content_bottom - 1, max(0, w - 2), "↓", 1, curses.A_DIM)
        except curses.error:
            pass

    if status:
        stdscr.addnstr(h - 1, 0, status[:w - 1], w - 1, curses.A_BOLD)
    stdscr.refresh()


def run_tui(stdscr, sections: list[Section]) -> str | None:
    curses.curs_set(0)
    cursor = 0
    status = ""
    scroll = [0]
    flat = flat_index(sections)
    while True:
        if not flat:
            return "no labels"
        cursor = max(0, min(cursor, len(flat) - 1))
        draw(stdscr, sections, cursor, status, scroll)
        status = ""
        c = stdscr.getch()
        if c in (ord("q"), 27):
            return None
        if c in (curses.KEY_DOWN, ord("j")):
            cursor = min(cursor + 1, len(flat) - 1)
        elif c in (curses.KEY_UP, ord("k")):
            cursor = max(cursor - 1, 0)
        elif c == curses.KEY_NPAGE:
            cursor = min(cursor + 10, len(flat) - 1)
        elif c == curses.KEY_PPAGE:
            cursor = max(cursor - 10, 0)
        elif c == ord(" "):
            flat[cursor].selected = not flat[cursor].selected
        elif c == ord("a"):
            for it in flat:
                it.selected = True
        elif c == ord("n"):
            for it in flat:
                it.selected = False
        elif c == ord("s"):
            sec = section_of(sections, flat[cursor])
            if sec:
                for it in sec.items:
                    it.selected = False
                status = f"unchecked section: {sec.title}"
        elif c == ord("S"):
            sec = section_of(sections, flat[cursor])
            if sec:
                for it in sec.items:
                    it.selected = True
                status = f"checked section: {sec.title}"
        elif c == ord("x"):
            sec = section_of(sections, flat[cursor])
            if sec:
                all_on = all(it.selected for it in sec.items)
                for it in sec.items:
                    it.selected = not all_on
                status = f"toggled section: {sec.title}"
        elif c == ord("]"):
            cursor = jump_section(sections, flat, cursor, direction=1)
        elif c == ord("["):
            cursor = jump_section(sections, flat, cursor, direction=-1)
        elif c == ord("r"):
            curses.endwin()
            if not prime_sudo():
                return "sudo failed"
            refresh_state(sections)
            stdscr.clear()
            status = "state reloaded"
        elif c in (curses.KEY_ENTER, 10, 13):
            curses.endwin()
            if not prime_sudo():
                return "sudo failed"
            result = apply_changes(sections)
            refresh_state(sections)
            stdscr.clear()
            straglen = len(result["stragglers"])
            status = (
                f'applied: {result["disabled"]} disabled, {result["enabled"]} enabled, '
                f'{result["killed"]} killed'
            )
            if straglen:
                status += f"  ⚠ {straglen} respawned (see terminal after quit)"
                # Print stragglers to stdout for visibility after TUI exits
                sys.stderr.write(f"\n[debloat] {straglen} stragglers (respawned by launchd):\n")
                for label, pids in result["stragglers"].items():
                    sys.stderr.write(f"  {label}  pids={pids}\n")


VERSION = "0.1.3"


def main() -> int:
    if len(sys.argv) > 1 and sys.argv[1] in ("-h", "--help"):
        print(__doc__ or "")
        print(f"\nUsage: debloat [-h|--help|-v|--version]\nVersion: {VERSION}")
        return 0
    if len(sys.argv) > 1 and sys.argv[1] in ("-v", "--version"):
        print(f"mac-os-debloat {VERSION}")
        return 0
    if LABELS_FILE and LABELS_FILE.exists():
        sections = parse_labels(LABELS_FILE)
        source_note = f"loaded labels from {LABELS_FILE}"
    else:
        sections = parse_labels(EMBEDDED_LABELS)
        source_note = "using embedded labels (no labels.txt found)"
    if not sections:
        print("no labels parsed", file=sys.stderr)
        return 1
    print(source_note)
    print("priming sudo...")
    if not prime_sudo():
        print("sudo required to read launchd state", file=sys.stderr)
        return 1
    refresh_state(sections)
    result = curses.wrapper(run_tui, sections)
    if result:
        print(result)
    return 0


if __name__ == "__main__":
    sys.exit(main())
